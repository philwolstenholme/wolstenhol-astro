---
export const prerender = true;

import { chunk } from "es-toolkit";
import { getSortedStars } from "../../helpers/getStarsSorted";
import Layout from "../../layouts/Layout.astro";
import Content from "../../components/Content.astro";
import PaginatedGrid from "../../components/PaginatedGrid.astro";
import GithubStarCard from "../../components/items/GithubStarCard.astro";

export async function getStaticPaths() {
  const ITEMS_PER_PAGE = 36;
  const BASE_PATH = "/github-stars";

  const items = await getSortedStars();
  const pages = chunk(items, ITEMS_PER_PAGE);

  return pages.map((pageItems, i) => ({
    params: { page: i === 0 ? undefined : String(i) },
    props: {
      items: pageItems,
      itemsPerPage: ITEMS_PER_PAGE,
      prevUrl: i === 0 ? null : i === 1 ? BASE_PATH : `${BASE_PATH}/${i - 1}`,
      nextUrl: i < pages.length - 1 ? `${BASE_PATH}/${i + 1}` : null,
    },
  }));
}

const { items, itemsPerPage, prevUrl, nextUrl } = Astro.props;
---

<Layout title="Github stars">
  <main class="py-8 md:py-12">
    <Content>
      <article>
        <h1
          class="text-fill-transparent bg-binding-dark slow-connection:bg-none bg-clip-text font-serif text-5xl font-bold tracking-tight xl:text-8xl"
        >
          Github stars
        </h1>
        <div
          class="mt-5 mb-10 space-y-5 font-serif text-xl leading-normal xl:mt-10 xl:mb-12 xl:text-2xl"
        >
          <p>
            A recent selection of projects that I've
            <a
              href="https://github.com/philwolstenholme?tab=stars"
              class="underline">starred on GitHub</a
            >.
          </p>
          <p>
            This page is part for me to big up the work of great projects, and
            part to serve as a personal bookmark of repos I find interesting and
            might want to check out or use later.
          </p>
        </div>
        <PaginatedGrid
          items={items}
          itemsPerPage={itemsPerPage}
          searchParam="githubStars"
          itemComponent={GithubStarCard}
          staticMode={true}
          prevUrl={prevUrl}
          nextUrl={nextUrl}
        />
      </article>
    </Content>
  </main>
</Layout>
