---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import Content from "../components/Content.astro";
import CurvyArrow from "../components/icons/CurvyArrow.astro";
import PageHeader from "../components/PageHeader.astro";

const suggestions = [
  { label: "The homepage", href: "/" },
  { label: "My work/portfolio", href: "/work" },
  { label: "Repos I've starred", href: "/github-stars" },
  { label: "The contact form", href: "/contact" },
];

// A slightly different lean each time the page is built keeps the note
// looking hand-stuck, like the reading list cards.
const noteRotation = `${(Math.random() * 2 - 1).toFixed(1)}deg`;
---

<Layout title="Page not found">
  <main class="py-8 md:py-12">
    <Content>
      <article class="max-w-3xl">
        <p class="font-serif text-xl font-bold">Oh no…</p>
        <PageHeader title="404" size="large">
          <p>
            Well, this is awkward. I've looked behind the coffee stains and
            under the masking tape, but{" "}
            <mark>this page isn't here</mark>. Maybe it never was, maybe I moved
            it, or maybe a URL got smudged somewhere along the way.
          </p>
        </PageHeader>

        <div
          class="max-w-xl border-2 border-black bg-accent bg-graph-paper p-8 shadow-ink-lg text-stone-900"
          style={`rotate: ${noteRotation}`}
        >
          <h2 class="font-serif text-2xl font-bold">
            Pages that definitely do exist
          </h2>
          <ul role="list" class="mt-4 space-y-2 font-serif text-lg">
            {
              suggestions.map((suggestion) => (
                <li class="flex items-center gap-2">
                  <CurvyArrow class="inline-block h-2.5 shrink-0 rotate-180 text-black" />
                  <a href={suggestion.href} class="underline hocus:text-black">
                    {suggestion.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <p class="mt-10 text-sm">
          Convinced this page should exist? <a
            href="/contact"
            class="underline hocus:text-yellow-600 dark:hocus:text-accent"
            >Let me know</a
          > and I'll go looking for it properly.
        </p>
      </article>
    </Content>
  </main>
</Layout>
