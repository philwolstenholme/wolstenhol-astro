---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Content from "../components/Content.astro";
import PaginatedGrid from "../components/PaginatedGrid.astro";
import GithubStarCard from "../components/items/GithubStarCard.astro";
import { getItemsPerPage } from "../helpers/getItemsPerPage";
import { setupPartial } from "../helpers/setupPartial";

export const prerender = false;

setupPartial(Astro, "githubStars", 0);

const itemsPerPage = getItemsPerPage({
  isMobile: Astro.locals.isMobile,
  mobileItemsPerPage: 10,
  desktopItemsPerPage: 36,
});

const collection = await getCollection("github-stars");
const items = collection.map((entry) => entry.data);
---

<Layout title="Github stars">
  <main class="py-8 md:py-12">
    <Content>
      <article>
        <h1
          class="text-fill-transparent bg-binding-dark bg-clip-text font-serif text-5xl font-bold tracking-tight xl:text-8xl"
        >
          Github stars
        </h1>
        <div
          class="mt-5 mb-10 space-y-5 font-serif text-xl leading-normal xl:mt-10 xl:mb-12 xl:text-2xl"
        >
          <p>
            A recent selection of projects that I've
            <a
              href="https://github.com/philwolstenholme?tab=stars"
              class="underline">starred on GitHub</a
            >.
          </p>
          <p>
            This page is part for me to big up the work of great projects, and
            part to serve as a personal bookmark of repos I find interesting and
            might want to check out or use later.
          </p>
        </div>
        <PaginatedGrid
          items={items}
          itemsPerPage={itemsPerPage}
          searchParam="githubStars"
          anchor="stars"
          itemComponent={GithubStarCard}
          htmxPartialPath="/partials/stars"
        />
      </article>
    </Content>
  </main>
</Layout>
