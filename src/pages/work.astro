---
import { getCollection, render } from "astro:content";
import slugify from "@sindresorhus/slugify";
import Layout from "../layouts/Layout.astro";
import Content from "../components/Content.astro";

export const prerender = true;

const entries = await getCollection("portfolio");
const sortedEntries = [...entries].sort((a, b) => {
  const weightDiff = (a.data.weight ?? 0) - (b.data.weight ?? 0);
  if (weightDiff !== 0) {
    return weightDiff;
  }
  return a.data.name.localeCompare(b.data.name);
});

const items = await Promise.all(
  sortedEntries.map(async (entry) => {
    const { Content: ItemContent } = await render(entry);
    return { data: entry.data, Content: ItemContent };
  }),
);

const urlToHostname = (url: string) => new URL(url).hostname;
---

<Layout title="Work/Portfolio">
  <main class="py-8 md:py-12">
    <Content>
      <article>
        <h1
          class="text-fill-transparent bg-binding-dark bg-clip-text font-serif text-5xl font-bold tracking-tight xl:text-8xl"
        >
          Work
        </h1>
        <div
          class="mt-5 mb-10 space-y-5 font-serif text-xl leading-normal xl:mt-10 xl:mb-12 xl:text-2xl"
        >
          <p class="highlight-links links-underline">
            I've helped design and build websites for <a
              href="#london-transport-museum">museums</a
            >, a
            <a href="#university-of-west-london">few</a>
            <a href="#manchester-metropolitan-university">different</a>
            <a href="#durham-university">universities</a> (3!), <a
              href="#london-gov-uk">regional</a
            > and
            <a href="#report-wreck-material">national</a> government, the <a
              href="#co-op-delivery">Co-op[erative]</a
            >, as well as the odd
            <a href="#project-nelson">aircraft carrier</a>…
          </p>
          <p>
            I enjoy producing modern, fast-performing sites that don't lose
            sight of the importance of accessibility and maintainability.
          </p>
        </div>
        <h2 class="mb-4 font-serif text-3xl font-bold xl:mb-5 xl:text-5xl">
          Some things I created or contributed to
        </h2>
        <p class="mt-3 mb-8 xl:mt-6 xl:mb-10">
          A portfolio of websites/web applications that I've worked on over the
          years.
        </p>
        <ul class="space-y-14 md:space-y-20">
          {
            items.map(({ data, Content }, index) => (
              <li
                tabindex="-1"
                class="card--portfolio transition-transform"
                id={slugify(data.name)}
              >
                <div class="flex grid-cols-2 flex-col gap-10 md:grid">
                  <div class={index % 2 !== 0 ? "col-start-2" : ""}>
                    <div class="grid">
                      <div
                        class="work-card__image-bg col-start-1 row-start-1 -rotate-3 transform rounded-2xl"
                        style={
                          data.color ? `--brand-colour: ${data.color}` : ""
                        }
                      />
                      {data.url && !data.prevent_link ? (
                        <a
                          class="relative col-start-1 row-start-1"
                          href={data.url}
                        >
                          <img
                            src={`https://res.cloudinary.com/wolstenh/image/upload/c_scale,w_560,f_auto,q_auto/${data.cloudinarySuffix}`}
                            srcset={`https://res.cloudinary.com/wolstenh/image/upload/c_scale,w_560,f_auto,q_auto/${data.cloudinarySuffix} 1x, https://res.cloudinary.com/wolstenh/image/upload/c_scale,w_1120,f_auto,q_auto/${data.cloudinarySuffix} 2x`}
                            width="548"
                            height="344"
                            loading={index > 0 ? "lazy" : "eager"}
                            fetchpriority={index > 0 ? "low" : "high"}
                            alt={`${urlToHostname(data.url)} screenshot`}
                            class="screenshot rounded-2xl border-2 border-white bg-white object-cover object-top shadow-hard"
                          />
                        </a>
                      ) : (
                        <img
                          src={`https://res.cloudinary.com/wolstenh/image/upload/c_scale,w_560,f_auto,q_auto/${data.cloudinarySuffix}`}
                          srcset={`https://res.cloudinary.com/wolstenh/image/upload/c_scale,w_1120,f_auto,q_auto/${data.cloudinarySuffix} 2x`}
                          width="548"
                          height="344"
                          loading={index > 0 ? "lazy" : "eager"}
                          alt={
                            data.url
                              ? `${urlToHostname(data.url)} screenshot`
                              : `${data.name} screenshot`
                          }
                          class="screenshot relative col-start-1 row-start-1 rounded-2xl border-2 border-white bg-white object-cover object-top shadow-hard"
                        />
                      )}
                    </div>
                  </div>
                  <div class={index % 2 !== 0 ? "col-start-1 row-start-1" : ""}>
                    <h3 class="mb-4 font-serif text-2xl font-bold xl:mb-5 xl:text-4xl">
                      {data.name}
                    </h3>
                    <div class="links-underline [&_li]:mb-2 [&_ul]:list-disc [&_ul]:pl-5">
                      <Content />
                    </div>
                  </div>
                </div>
              </li>
            ))
          }
        </ul>
      </article>
    </Content>
  </main>
</Layout>
