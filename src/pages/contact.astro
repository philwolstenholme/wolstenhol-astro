---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import Content from "../components/Content.astro";
---

<Layout title="Contact me">
  <main class="py-8 md:py-12">
    <Content>
      <article>
        <h1
          class="text-fill-transparent bg-binding-dark slow-connection:bg-none bg-clip-text font-serif text-5xl font-bold tracking-tight xl:text-8xl"
        >
          Contact me
        </h1>
        <div
          class="mt-5 mb-10 space-y-5 font-serif text-xl leading-normal xl:mt-10 xl:mb-12 xl:text-2xl"
        >
          <p>
            You can send me a direct message on{" "}
            <a
              class="underline hocus:text-yellow-600"
              href="https://bsky.app/profile/wolstenhol.me">Bluesky</a
            > or drop me an email via this contact form (all fields are required).
          </p>
          <p class="text-base xl:text-lg">
            <strong>Note:</strong> this form is for genuine personal enquiries only
            — not for sales pitches, SEO offers, or requests for commercial estimates.
          </p>
        </div>

        <div x-data="pwContact">
          <!-- Success message -->
          <div
            x-show="submitted"
            x-cloak
            class="rounded-lg border-2 border-green-600 bg-green-50 p-6 text-green-900"
            role="alert"
          >
            <h2 class="mb-2 font-serif text-2xl font-bold">Message sent!</h2>
            <p>
              Thanks for getting in touch. I'll get back to you as soon as I
              can.
            </p>
          </div>

          <!-- Server error message -->
          <div
            x-show="submitError"
            x-cloak
            class="mb-6 rounded-lg border-2 border-red-600 bg-red-50 p-4 text-red-900"
            role="alert"
          >
            <p>
              Something went wrong sending your message. Please try again or
              contact me directly on <a
                class="underline"
                href="https://bsky.app/profile/wolstenhol.me">Bluesky</a
              >.
            </p>
          </div>

          <!-- Contact form -->
          <form
            x-show="!submitted"
            name="contact"
            data-netlify="true"
            netlify-honeypot="bot-field"
            hx-post="/contact"
            hx-trigger="pwContactSubmit"
            hx-swap="none"
            class="space-y-6"
            novalidate
          >
            <input type="hidden" name="form-name" value="contact" />

            <!-- Honeypot -->
            <p class="hidden" aria-hidden="true">
              <label>
                Don't fill this out if you're human:
                <input name="bot-field" tabindex="-1" autocomplete="off" />
              </label>
            </p>

            <!-- Name -->
            <div class="space-y-1">
              <label for="contact-name" class="block font-bold">
                Name <span aria-hidden="true" class="text-red-600">*</span>
              </label>
              <input
                type="text"
                id="contact-name"
                name="name"
                required
                minlength="2"
                autocomplete="name"
                x-model="values.name"
                x-on:blur="touch('name')"
                x-bind:aria-invalid="touched.name && !!errors.name ? 'true' : 'false'"
                x-bind:aria-describedby="touched.name && errors.name ? 'contact-name-error' : null"
                class="w-full rounded border-2 border-gray-300 px-3 py-2 shadow-sm focus:border-gray-900 focus:outline-none"
                x-bind:class="{ 'border-red-500 bg-red-50': touched.name && errors.name }"
              />
              <p
                id="contact-name-error"
                role="alert"
                class="text-sm text-red-700"
                x-show="touched.name && errors.name"
                x-text="errors.name"
                x-cloak
              >
              </p>
            </div>

            <!-- Email -->
            <div class="space-y-1">
              <label for="contact-email" class="block font-bold">
                Email <span aria-hidden="true" class="text-red-600">*</span>
              </label>
              <input
                type="email"
                id="contact-email"
                name="email"
                required
                autocomplete="email"
                x-model="values.email"
                x-on:blur="touch('email')"
                x-bind:aria-invalid="touched.email && !!errors.email ? 'true' : 'false'"
                x-bind:aria-describedby="touched.email && errors.email ? 'contact-email-error' : null"
                class="w-full rounded border-2 border-gray-300 px-3 py-2 shadow-sm focus:border-gray-900 focus:outline-none"
                x-bind:class="{ 'border-red-500 bg-red-50': touched.email && errors.email }"
              />
              <p
                id="contact-email-error"
                role="alert"
                class="text-sm text-red-700"
                x-show="touched.email && errors.email"
                x-text="errors.email"
                x-cloak
              >
              </p>
            </div>

            <!-- Subject -->
            <div class="space-y-1">
              <label for="contact-subject" class="block font-bold">
                Subject <span aria-hidden="true" class="text-red-600">*</span>
              </label>
              <input
                type="text"
                id="contact-subject"
                name="subject"
                required
                minlength="8"
                x-model="values.subject"
                x-on:blur="touch('subject')"
                x-bind:aria-invalid="touched.subject && !!errors.subject ? 'true' : 'false'"
                x-bind:aria-describedby="touched.subject && errors.subject ? 'contact-subject-error' : null"
                class="w-full rounded border-2 border-gray-300 px-3 py-2 shadow-sm focus:border-gray-900 focus:outline-none"
                x-bind:class="{ 'border-red-500 bg-red-50': touched.subject && errors.subject }"
              />
              <p
                id="contact-subject-error"
                role="alert"
                class="text-sm text-red-700"
                x-show="touched.subject && errors.subject"
                x-text="errors.subject"
                x-cloak
              >
              </p>
            </div>

            <!-- Message -->
            <div class="space-y-1">
              <label for="contact-message" class="block font-bold">
                Message <span aria-hidden="true" class="text-red-600">*</span>
              </label>
              <textarea
                id="contact-message"
                name="message"
                required
                minlength="8"
                rows="6"
                x-model="values.message"
                x-on:blur="touch('message')"
                x-bind:aria-invalid="touched.message && !!errors.message ? 'true' : 'false'"
                x-bind:aria-describedby="touched.message && errors.message ? 'contact-message-error' : null"
                class="w-full rounded border-2 border-gray-300 px-3 py-2 shadow-sm focus:border-gray-900 focus:outline-none"
                x-bind:class="{ 'border-red-500 bg-red-50': touched.message && errors.message }"
              ></textarea>
              <p
                id="contact-message-error"
                role="alert"
                class="text-sm text-red-700"
                x-show="touched.message && errors.message"
                x-text="errors.message"
                x-cloak
              >
              </p>
            </div>

            <!-- Agreement checkbox -->
            <div class="space-y-1">
              <div class="flex items-start gap-3">
                <input
                  type="checkbox"
                  id="contact-agreement"
                  name="agreement"
                  required
                  class="mt-1 size-4 shrink-0 cursor-pointer rounded border-2 border-gray-300 accent-yellow-400"
                  x-on:change="values.agreement = $el.checked ? 'true' : ''; touch('agreement')"
                  x-bind:aria-invalid="touched.agreement && !!errors.agreement ? 'true' : 'false'"
                  x-bind:aria-describedby="touched.agreement && errors.agreement ? 'contact-agreement-error' : null"
                />
                <label
                  for="contact-agreement"
                  class="cursor-pointer text-sm leading-snug"
                >
                  I understand this form is for personal enquiries only, not for
                  sales pitches or commercial work requests. <span
                    aria-hidden="true"
                    class="text-red-600">*</span
                  >
                </label>
              </div>
              <p
                id="contact-agreement-error"
                role="alert"
                class="text-sm text-red-700"
                x-show="touched.agreement && errors.agreement"
                x-text="errors.agreement"
                x-cloak
              >
              </p>
            </div>

            <!-- Submit button -->
            <div>
              <button
                type="button"
                x-on:click="submit($el.closest('form'))"
                class="inline-flex cursor-pointer items-center gap-2 rounded border-2 border-black bg-yellow-300 px-5 py-3 font-bold shadow-hard transition-transform active:scale-95 hocus:bg-yellow-400"
              >
                Send message
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 256 256"
                  fill="currentColor"
                  width="20"
                  height="20"
                  aria-hidden="true"
                >
                  <path
                    d="M231.4,44.34a12,12,0,0,0-12.06-3L24.12,106.31a12,12,0,0,0-1.76,22.1l86.9,49.88,49.88,86.9A12,12,0,0,0,170,272a12.2,12.2,0,0,0,1.23-.07,12,12,0,0,0,9.54-7.29L234.4,56.44a12,12,0,0,0-3-12.1ZM178.64,220.31l-42.26-73.63,24.42-24.42a12,12,0,0,0-17-17L119.4,129.64,45.77,87.36,207.26,48.74Z"
                  ></path>
                </svg>
              </button>
            </div>
          </form>
        </div>
      </article>
    </Content>
  </main>
</Layout>
