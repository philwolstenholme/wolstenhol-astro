---
export const prerender = false;

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=300, stale-while-revalidate=3600",
);
Astro.response.headers.set("Netlify-CDN-Cache-Control", "s-maxage=31536000");
Astro.response.headers.set("X-Robots-Tag", "noindex");

import { getCollection } from "astro:content";
import { paginate, buildPageHref } from "../../helpers/paginate";
import { getItemsPerPage } from "../../helpers/getItemsPerPage";
import PaginatedGrid from "../../components/PaginatedGrid.astro";
import SpeakingCard from "../../components/items/SpeakingCard.astro";

const searchParam = "speaking";
const htmxPartialPath = "/partials/speaking";
const itemsPerPage =
  Number(Astro.url.searchParams.get("perPage")) ||
  getItemsPerPage({
    astroRequest: Astro.request,
    mobileItemsPerPage: 5,
    desktopItemsPerPage: 12,
  });

const collection = await getCollection("speaking");
const items = collection.map((entry) => entry.data);

const { index } = paginate({
  items,
  itemsPerPage,
  url: new URL(Astro.request.url),
  searchParam,
  onlyFullPages: true,
});

const htmxCurrentUrl = Astro.request.headers.get("HX-Current-Url");
const pageUrl = htmxCurrentUrl ? new URL(htmxCurrentUrl) : undefined;
if (htmxCurrentUrl) {
  Astro.response.headers.set(
    "HX-Replace-Url",
    buildPageHref({
      currentUrl: new URL(htmxCurrentUrl),
      param: searchParam,
      index,
    }),
  );
}
---

<PaginatedGrid
  items={items}
  itemsPerPage={itemsPerPage}
  searchParam={searchParam}
  itemComponent={SpeakingCard}
  htmxPartialPath={htmxPartialPath}
  pageUrl={pageUrl}
/>
