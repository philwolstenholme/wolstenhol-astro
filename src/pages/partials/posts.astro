---
export const prerender = false;

import { preparePartialPage } from "../../helpers/preparePartialPage";
import { getSortedDevToPosts } from "../../helpers/getDevToPostsSorted";
import PaginatedGrid from "../../components/PaginatedGrid.astro";
import DevToPostCard from "../../components/items/DevToPostCard.astro";

const searchParam = "posts";
const htmxPartialPath = "/partials/posts";

const items = await getSortedDevToPosts();

const { itemsPerPage, pageUrl } = preparePartialPage(Astro, {
  items,
  searchParam,
  itemsPerPage: 3,
});
---

<PaginatedGrid
  items={items}
  itemsPerPage={itemsPerPage}
  searchParam={searchParam}
  itemComponent={DevToPostCard}
  htmxPartialPath={htmxPartialPath}
  pageUrl={pageUrl}
/>
