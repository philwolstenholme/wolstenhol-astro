---
export const prerender = false;

import { getCollection } from "astro:content";
import { paginate } from "../../helpers/paginate";
import { setupPartial } from "../../helpers/setupPartial";
import PaginatedGrid from "../../components/PaginatedGrid.astro";
import DevToPostCard from "../../components/items/DevToPostCard.astro";

const searchParam = "posts";
const itemsPerPage = 3;
const htmxPartialPath = "/partials/posts";

const collection = await getCollection("dev-to-posts");
const items = collection.map((entry) => entry.data);

const { index } = paginate({
  items,
  itemsPerPage,
  url: new URL(Astro.request.url),
  searchParam,
  onlyFullPages: true,
});

const pageUrl = setupPartial(Astro, searchParam, index);
---

<PaginatedGrid
  items={items}
  itemsPerPage={itemsPerPage}
  searchParam={searchParam}
  itemComponent={DevToPostCard}
  htmxPartialPath={htmxPartialPath}
  pageUrl={pageUrl}
/>
