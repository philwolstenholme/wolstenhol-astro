---
export const prerender = false;

import { getCollection } from "astro:content";
import { preparePartialPage } from "../../helpers/preparePartialPage";
import PaginatedGrid from "../../components/PaginatedGrid.astro";
import ReadingListCard from "../../components/items/ReadingListCard.astro";
import { mergeReadingLists } from "../../helpers/mergeReadingLists";

const searchParam = "readingList";
const htmxPartialPath = "/partials/reading-list";

const [devToCollection, airtableCollection] = await Promise.all([
  getCollection("dev-to-reading-list"),
  getCollection("airtable-reading-list"),
]);

const items = mergeReadingLists(devToCollection, airtableCollection);

const { itemsPerPage, pageUrl } = preparePartialPage(Astro, {
  items,
  searchParam,
});
---

<PaginatedGrid
  items={items}
  itemsPerPage={itemsPerPage}
  searchParam={searchParam}
  itemComponent={ReadingListCard}
  htmxPartialPath={htmxPartialPath}
  pageUrl={pageUrl}
/>
