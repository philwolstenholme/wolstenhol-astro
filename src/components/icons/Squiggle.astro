---
// A hand-drawn underline beneath headings, giving them the same marker-pen
// feel as the highlighter effect and the handwritten SVGs. The .squiggle
// utility tiles a seamless squiggle SVG, so it fills whatever width the
// parent gives it — size it with height/margin utilities via `class`.
export interface SquiggleProps {
  class?: string;
}

const { class: className } = Astro.props;
---

<span class:list={["squiggle", className]} aria-hidden="true"></span>
