---
import type { CollectionEntry } from "astro:content";

type Place = CollectionEntry<"places">["data"] & { id: string };
const { item: place } = Astro.props as { item: Place };

function timeAgo(dateStr: string): string {
  const date = new Date(dateStr);
  const diffMs = Date.now() - date.getTime();
  const diffDays = Math.floor(diffMs / 86_400_000);
  const diffMonths = Math.floor(diffDays / 30);
  const diffYears = Math.floor(diffDays / 365);
  const rtf = new Intl.RelativeTimeFormat("en-GB", { numeric: "auto" });
  if (diffYears >= 1) return rtf.format(-diffYears, "year");
  if (diffMonths >= 1) return rtf.format(-diffMonths, "month");
  if (diffDays >= 1) return rtf.format(-diffDays, "day");
  return "today";
}

const formattedAddress = [place.address, place.city].filter(Boolean).join(", ");
const grungeOpacity = Math.round((Math.random() / 3) * 100) / 100;
const asteriskRotation = Math.floor(Math.random() * 360) + 1;
---

<li
  class="expand-clickable-area font-serif bg-foursquare shadow-hard border border-foursquare-dark rounded overflow-hidden transition-all duration-75 hover:scale-105 hover:shadow-lg focus-within:scale-105 focus-within:shadow-lg"
>
  <div class="group flex flex-col-reverse h-full">
    <div class="p-4 space-y-2">
      <h3 class="font-bold text-white leading-tight text-base">
        <span aria-hidden="true" class="mr-1">♥</span>
        {
          place.url ? (
            <a href={place.url} class="group-hocus:underline text-white">
              {place.name}
            </a>
          ) : (
            <span>{place.name}</span>
          )
        }
      </h3>
      <div class="space-y-1 text-xs font-bold text-white">
        {place.tip && <p>{place.tip}</p>}
        <p>{formattedAddress}</p>
      </div>
    </div>

    <div class="relative grid-stack overflow-hidden" style="height: 182px;">
      {
        place.mapUrl ? (
          <img
            src={place.mapUrl}
            alt={`Map showing location of ${place.name} in ${place.city}`}
            width="365"
            height="182"
            loading="lazy"
            class="w-full h-full object-cover mix-blend-multiply"
          />
        ) : (
          <div class="w-full h-full bg-foursquare-dark/30" />
        )
      }

      <img
        alt=""
        loading="lazy"
        width="365"
        height="182"
        srcset="https://wolstenhol.me/proxy/cloudinary/image/upload/c_fill%2Cg_north%2Cw_365%2Ch_182%2Cf_auto%2Cq_auto%3Alow%2Fv1661284312%2Fone-offs%2F9-soft-grunge-texture-4-1.png 1x, https://wolstenhol.me/proxy/cloudinary/image/upload/c_fill%2Cg_north%2Cw_730%2Ch_364%2Cf_auto%2Cq_auto%3Alow%2Fv1661284312%2Fone-offs%2F9-soft-grunge-texture-4-1.png 2x"
        class="opacity-grunge block h-full w-full object-cover"
        style={`--opacity: ${grungeOpacity}`}
      />

      <div class="flex items-center justify-center">
        <svg
          aria-hidden="true"
          role="presentation"
          focusable="false"
          viewBox="0 0 128.2 138.9"
          class="h-8 w-8 text-white transition-transform duration-75 group-hocus:-translate-y-1"
          style={`rotate: ${asteriskRotation}deg`}
        >
          <path
            fill="currentColor"
            d="M57 2c-3 1-3 4-2 6l3 19 2 17c0 2-3 0-4-1L42 32l-11-7c-3-1-4 1-6 3-1 1-2 4 0 5l6 5 20 19c3 3 7 6 8 10 0 3-3 2-4 2l-35-1-10-1c-3 0-5 3-7 4s-3 3-3 5 2 3 4 4l9 1 26 1c2 0 3 2 1 3l-14 17c0 2-3 2-4 4l-4 4c-1 2-3 3-3 6-1 2-3 4-3 7s1 7 4 8c2 1 4-1 5-3l5-8 16-18 17-15c2-1 3-3 5-3 3 0 3 3 3 4l2 16v32c1 2 4 1 6 1 2-1 3-4 3-6l3-15 2-10c2 0 2 3 3 4l4 11 1 17c1 2 4 0 5 0 2-1 4-2 4-4l1-16-3-12-8-20c0-2 3-2 5-2 9 0 19 1 28-1 4 0 6-5 5-8-2-2-5-2-7-3-4-1-8-2-13-1H91l-4-1c-1-2 2-3 3-4l8-6 6-5 14-17 1-4c0-3-1-6-3-7-4-1-8 0-10 3l-4 3-14 14-7 5c-1 1-2 4-3 2l-3-15-3-14-5-23c-2-2-4-2-6-2l-4 2Z"
          ></path>
        </svg>
      </div>

      <div
        style="background: radial-gradient(circle, rgba(255,255,255,0) 30%, rgb(0 0 0 / 40%) 100%);"
      >
      </div>

      {
        place.likedAt && (
          <p class="absolute left-3 top-2 text-xs text-white uppercase font-bold drop-shadow z-10 isolate">
            {timeAgo(place.likedAt)}
          </p>
        )
      }
    </div>
  </div>
</li>
