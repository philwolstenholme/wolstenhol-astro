---
import type { CollectionEntry } from "astro:content";
import { getRandomRotation } from "../../helpers/getRandomRotation";

const { item: article } = Astro.props as {
  item: CollectionEntry<"dev-to-reading-list">["data"]["article"];
};

// Give each card a slight, randomised tilt at render time, like the original
// site. The standalone `rotate` property composes with the `hover:scale-105`
// lift so the card straightens out a touch as it grows.
const rotation = getRandomRotation();
---

<li
  class="expand-clickable-area row-span-2 grid grid-rows-subgrid p-4 font-serif bg-oc-yellow-2 bg-paper-grunge shadow-hard border border-gray-300 rounded transition-all duration-75 hover:scale-105 hover:bg-oc-yellow-3 hover:shadow-lg focus-within:scale-105 focus-within:bg-oc-yellow-3 focus-within:shadow-lg"
  style={rotation ? `rotate: ${rotation}` : undefined}
>
  <a href={article.url} class="text-binding-dark font-bold row-span-1">
    {article.title}
  </a>
  <p class="text-sm line-clamp-3 row-span-1">{article.description}</p>
</li>
