---
import { NAV_SCROLL_RESTORE_SCRIPT } from "../assets/csp-inline-assets";

interface NavLink {
  href: string;
  label: string;
}

const navLinks: NavLink[] = [
  { href: "/#words", label: "Words" },
  { href: "/#reading", label: "Reading" },
  { href: "/#speaking", label: "Speaking" },
  { href: "/#music", label: "Music" },
  { href: "/#photos", label: "Photos" },
  { href: "/#posts", label: "Posts" },
  { href: "/#places", label: "Places" },

  // Keep anchor links to the homepage grouped ABOVE this line, below this are links to other pages.

  { href: "/work", label: "Work" },
  { href: "/contact", label: "Contact" },
  { href: "/github-stars", label: "Starred" },
];
---

<header
  class="w-full h-12 sticky top-0 z-1000 bg-binding-dark slow-connection:bg-none text-white py-2 constrain-content sm:px-2"
  x-data="pwHeader"
  x-load="idle"
>
  <div class="flex space-x-4">
    <a
      href="/#content"
      rel="home"
      class="block shrink-0 w-8 h-8"
      aria-label="Home"
    >
      <span class="sr-only">Home</span>
      <img
        alt="Phil Wolstenholme"
        class="inline-block size-8 rounded-full bg-yellow-300 transition-transform duration-300 hover:-rotate-6 hover:scale-110 hover:transform-gpu"
        src="/proxy/cloudinary/image/upload/c_scale,f_auto,q_auto,w_32/v1545084898/avatar_egzcjk.png"
        srcset="/proxy/cloudinary/image/upload/c_scale,f_auto,q_auto,w_64/v1545084898/avatar_egzcjk.png 2x"
        width="32"
        height="32"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </a>
    <nav
      class="header-nav relative flex flex-1 items-center overscroll-contain overflow-x-auto scrollbar-none"
      role="navigation"
      aria-label="Page sections"
    >
      <h2 class="sr-only">In-page navigation</h2>
      <div
        class="header-nav--indicator pointer-events-none shrink-0 bg-binding-dark header-nav--indicator__left sticky left-0 top-0 bottom-0"
      >
      </div>
      <ul
        role="list"
        class="header-nav__list flex items-center space-x-3"
        x-ref="list"
      >
        {
          navLinks.map((link, i) => {
            const isPageLink = !link.href.includes("#");
            const prevIsAnchorLink =
              i > 0 && navLinks[i - 1].href.includes("#");
            return (
              <>
                {isPageLink && prevIsAnchorLink && (
                  <li aria-hidden="true" class="select-none text-white/40">
                    •
                  </li>
                )}
                <li class="shrink-0">
                  <a
                    href={link.href}
                    class="font-bold font-serif underline hocus:text-yellow-300"
                    x-bind:class="{ 'text-yellow-300': isActive($el) }"
                  >
                    {link.label}
                  </a>
                </li>
              </>
            );
          })
        }
      </ul>
      <div
        class="header-nav--indicator pointer-events-none shrink-0 bg-binding-dark header-nav--indicator__right sticky right-0 top-0 bottom-0"
      >
      </div>
    </nav>
    <!-- Restores the nav's horizontal scroll position before first paint so
         hard navigations feel like an SPA instead of resetting the scroll.
         Placed right after .header-nav so it runs synchronously, once that
         element (and its children, which its scrollWidth depends on) has
         been parsed but before the browser paints the frame. Speculation-
         rules prerendered pages run this script before a later scroll on the
         referring page is saved, and bfcache restores can race with it too,
         so it re-syncs at activation in both cases (see the script body in
         ../assets/csp-inline-assets.ts, kept there so its CSP hash in
         src/middleware.ts can't drift out of sync with what renders). -->
    <script is:inline set:html={NAV_SCROLL_RESTORE_SCRIPT} />
  </div>
  <div
    class="sm:-mx-2 col-[full] bg-binding-dark h-3 shadow-hard"
    style="transform: skewY(-0.3deg)"
  >
  </div>
</header>
