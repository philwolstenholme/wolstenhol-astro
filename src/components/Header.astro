---
interface NavLink {
  label: string;
  href: string;
  hash?: string;
  path?: string;
}

const navLinks: NavLink[] = [
  { label: "Words", href: "/#words", hash: "#words" },
  { label: "Reading", href: "/#reading", hash: "#reading" },
  { label: "Speaking", href: "/#speaking", hash: "#speaking" },
  { label: "Music", href: "/#music", hash: "#music" },
  // { label: "Photos", href: "/#photos", hash: "#photos" },
  // { label: "Posts", href: "/#posts", hash: "#posts" },
  { label: "Places", href: "/#places", hash: "#places" },
  { label: "Work", href: "/work", path: "/work" },
  // { label: "Contact", href: "/contact", path: "/contact" },
  { label: "Starred", href: "/github-stars", path: "/github-stars" },
];
---

<header
  class="w-full h-12 sticky top-0 z-1000 bg-binding-dark slow-connection:bg-none text-white py-2 px-5 sm:px-2"
  x-data="pwHeader"
>
  <div class="section__inner mx-auto flex space-x-4">
    <a
      href="/#content"
      rel="home"
      class="block shrink-0 w-8 h-8"
      aria-label="Home"
    >
      <span class="sr-only">Home</span>
      <img
        alt="Phil Wolstenholme"
        class="inline-block size-8 rounded-full bg-yellow-300"
        src="https://wolstenhol.me/proxy/cloudinary/image/upload/c_scale,f_auto,q_auto,w_32/v1545084898/avatar_egzcjk.png"
        srcset="https://wolstenhol.me/proxy/cloudinary/image/upload/c_scale,f_auto,q_auto,w_64/v1545084898/avatar_egzcjk.png 2x"
        width="32"
        height="32"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </a>
    <nav
      class="header-nav relative flex flex-1 items-center overscroll-contain overflow-x-auto hide-scrollbars"
      role="navigation"
      aria-label="Page sections"
    >
      <h2 class="sr-only">In-page navigation</h2>
      <div
        class="header-nav--indicator pointer-events-none shrink-0 bg-binding-dark header-nav--indicator__left sticky left-0 top-0 bottom-0"
      >
      </div>
      <ul
        role="list"
        class="header-nav__list flex items-center space-x-3"
        x-ref="list"
      >
        {
          navLinks.map((link) => (
            <li class="shrink-0">
              <a
                href={link.href}
                data-hash={link.hash ?? ""}
                data-path={link.path ?? ""}
                class="font-bold font-serif underline hocus:text-yellow-300"
                x-bind:class="{ 'text-yellow-300': isActive($el.dataset.hash, $el.dataset.path) }"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
      <div
        class="header-nav--indicator pointer-events-none shrink-0 bg-binding-dark header-nav--indicator__right sticky right-0 top-0 bottom-0"
      >
      </div>
    </nav>
  </div>
  <div
    class="-mx-5 sm:-mx-2 bg-binding-dark h-3 shadow-hard"
    style="transform: skewY(-0.3deg)"
  >
  </div>
</header>
