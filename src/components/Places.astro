---
import { getCollection } from "astro:content";
import { Section } from "./Section";
import Lede from "./Lede.astro";
import PaginatedGrid from "./PaginatedGrid.astro";
import PlacesCard from "./items/PlacesCard.astro";
import { getItemsPerPage } from "../helpers/getItemsPerPage";
import { sortBy } from "es-toolkit";

const searchParam = "places";
const anchor = "places";
const itemsPerPage = getItemsPerPage({
  astroRequest: Astro.request,
  mobileItemsPerPage: 4,
  desktopItemsPerPage: 6,
});

const placesCollection = await getCollection("places");
const items = sortBy(
  placesCollection.map((entry) => ({ id: entry.id, ...entry.data })),
  [(p) => (p.likedAt ? -new Date(p.likedAt).getTime() : Infinity)],
);
---

<Section heading="Places">
  <Lede>
    <p class="max-w-3xl font-serif leading-relaxed tracking-widest mt-3">
      A randomised asortment of places I've liked on Foursquare at one point -
      it could be somewhere from a holiday, or it could be a random bar in
      Manchester that closed thirteen years ago…
    </p>
  </Lede>
  <div class="mt-8">
    <PaginatedGrid
      items={items}
      itemsPerPage={itemsPerPage}
      searchParam={searchParam}
      anchor={anchor}
      itemComponent={PlacesCard}
    >
      <p slot="empty" class="text-center text-gray-500 py-8">
        No places found. Add some to <code>src/content/places.json</code>.
      </p>
    </PaginatedGrid>
  </div>
</Section>
