---
import clsx from "clsx";
import ScrollerArrow from "./ScrollerArrow.astro";

interface Props {
  label: string;
  theme?: "instagram" | "speaking" | "spotify";
  scrollFull?: boolean;
  class?: string;
}

const {
  label,
  theme = "speaking",
  scrollFull = false,
  class: className,
} = Astro.props;

const themeArrowClasses = {
  instagram: "text-instagram hocus:text-instagram-dark",
  speaking: "text-purple-700 hocus:text-purple-800",
  spotify: "text-green-700 hocus:text-green-800",
};

const themeButtonClasses = {
  instagram: "bg-instagram hocus:bg-instagram-dark",
  speaking: "bg-purple-700 hocus:bg-purple-800",
  spotify: "bg-green-700 hocus:bg-green-600",
};
---

<div
  class={clsx("col-[full]", className)}
  x-data={`horizontalScroller({ scrollFull: ${scrollFull} })`}
  x-load="idle"
>
  {
    /*
    Scroller row. Buttons are positioned absolutely within this div so their
    vertical extent is bounded by the scroller height alone, not the row below.
  */
  }
  <div class="relative">
    <ScrollerArrow direction="left" themeClass={themeArrowClasses[theme]} />

    <div class="relative overflow-x-hidden">
      <div
        x-cloak
        class="scroller-affordance pointer-events-none absolute bottom-5 left-0 top-0 z-10 w-3 rotate-180 transform-gpu transition-transform"
        x-bind:class="{ '-translate-x-3': !overflowing.left }"
      >
      </div>

      <ul
        x-ref="scroller"
        role="list"
        aria-label={label}
        class="scroller-x-pad relative flex snap-x snap-mandatory gap-5 overflow-x-auto overscroll-x-none scroll-smooth [&::-webkit-scrollbar]:hidden scrollbar-none"
      >
        <slot />
      </ul>

      <div
        x-cloak
        class="scroller-affordance pointer-events-none absolute bottom-5 right-0 top-0 z-10 w-3 transform-gpu transition-transform"
        x-bind:class="{ 'translate-x-3': !overflowing.right }"
      >
      </div>
    </div>

    <ScrollerArrow direction="right" themeClass={themeArrowClasses[theme]} />
  </div>

  {
    /*
    "There's more" row: uses scroller-x-pad so it aligns with the content
    column, matching headings and body text above the scroller.
  */
  }
  <div class="scroller-x-pad flex h-10 justify-end">
    <div
      class="ml-3 mt-3 transform-gpu rounded text-sm font-bold text-gray-600 transition-all duration-300 dark:text-stone-300"
      x-bind:class="{ 'opacity-0 translate-y-4 pointer-events-none': !overflowing.right }"
    >
      <span>There&rsquo;s more!</span>
      <button
        type="button"
        class={clsx(
          "ml-1 rounded px-2 py-1 font-bold text-white shadow-hard transition-colors",
          themeButtonClasses[theme],
        )}
        x-on:click="scrollRight()"
      >
        scroll this way <span aria-hidden="true">➜</span>
      </button>
    </div>
  </div>
</div>
