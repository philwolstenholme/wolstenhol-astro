---
import clsx from "clsx";

import Squiggle from "./icons/Squiggle.astro";

interface Props {
  [key: string]: unknown;
  class?: string;
  hasScroller?: boolean;
  heading?: string;
  id?: string;
}

const {
  class: className = "",
  hasScroller = false,
  heading,
  id,
  ...rest
} = Astro.props;
---

<section
  class={clsx(
    className,
    "group/section",
    hasScroller && "col-[full] constrain-content",
  )}
  id={id}
  {...rest}
>
  {
    heading && (
      <div class="mt-3 flex flex-wrap items-baseline gap-x-4 gap-y-3">
        <h2
          class="text-4xl font-bold font-serif scroll-mt-8 w-fit"
          data-section={id}
        >
          {heading}
          <Squiggle class="mt-1 block h-2 w-24 -rotate-1 text-yellow-400" />
        </h2>
        <slot name="heading-extra" />
      </div>
    )
  }
  <slot />
</section>
