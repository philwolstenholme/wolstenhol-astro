---
import clsx from "clsx";

import Squiggle from "./icons/Squiggle.astro";

// Shared page-title treatment (gradient-filled heading with a hand-drawn
// squiggle underneath, followed by the serif intro) used by every
// non-homepage page. The default slot holds the intro paragraphs.
interface Props {
  size?: "default" | "large";
  title: string;
}

const { size = "default", title } = Astro.props;
---

<h1
  class={clsx(
    "w-fit text-fill-transparent bg-binding-dark slow-connection:bg-none bg-clip-text font-serif font-bold tracking-tight",
    size === "large" ? "text-8xl xl:text-9xl" : "text-5xl xl:text-8xl",
  )}
>
  {title}
  <Squiggle
    class="mt-2 block h-2.5 w-36 -rotate-1 text-yellow-400 xl:mt-3 xl:h-3 xl:w-56"
  />
</h1>
<div
  class="mt-5 mb-10 space-y-5 font-serif text-xl leading-normal xl:mt-10 xl:mb-12 xl:text-2xl"
>
  <slot />
</div>
