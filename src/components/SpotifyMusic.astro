---
import type { CollectionEntry } from "astro:content";

import type { SpotifyArtist } from "./SpotifyAudioController.astro";

import HorizontalScroller from "./HorizontalScroller.astro";
import SpotifyMusicCard from "./items/SpotifyMusicCard.astro";
import Section from "./Section.astro";
import SpotifyAudioController from "./SpotifyAudioController.astro";
import SpotifyGenresLede from "./SpotifyGenresLede.astro";

interface Props {
  data: CollectionEntry<"spotify"> | undefined;
}

const { data } = Astro.props;

if (!data) {
  return;
}

const { artists, randomGenres } = data.data;
---

<svg
  aria-hidden="true"
  focusable="false"
  class="absolute size-0 overflow-hidden"
>
  <defs>
    <filter id="spotify-grain">
      <feTurbulence
        type="fractalNoise"
        baseFrequency="0.65"
        numOctaves="3"
        stitchTiles="stitch"></feTurbulence>
      <feColorMatrix type="saturate" values="0"></feColorMatrix>
    </filter>
  </defs>
</svg>
<Section id="music" hasScroller heading="Music">
  <SpotifyGenresLede genres={randomGenres} />
  <div class="col-[full] group/player relative mt-12" data-spotify-player>
    <HorizontalScroller
      label="What I've been listening to"
      theme="spotify"
      scrollFull={true}
    >
      {
        (artists as SpotifyArtist[]).map((artist, i) => (
          <li tabindex="-1" class="relative mb-3 shrink-0 grow-0 snap-center">
            <SpotifyMusicCard artist={artist} index={i} />
          </li>
        ))
      }
    </HorizontalScroller>
    <SpotifyAudioController artists={artists as SpotifyArtist[]} />
  </div>
  <p class="mt-4 max-w-prose text-xs font-bold opacity-90">
    You can click the cards above to play a little preview of the artist,
    courtesy of the Spotify API. I also use the Spotify API to get the tempo/BPM
    of the preview song, and I use this to influence the speed that a card bops
    at while it&rsquo;s playing.
  </p>
  <p class="mt-2 pb-0.5 text-xs">
    Press the pause icon or the{" "}
    <kbd
      class="rounded border border-gray-300 bg-white p-0.5 dark:border-stone-600 dark:bg-stone-800"
      >esc</kbd
    > key to stop.
  </p>
</Section>
