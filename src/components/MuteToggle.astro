---

---

<button
  id="mute-toggle"
  x-data="{
    muted: false,
    init() { this.muted = localStorage.getItem('audioMuted') === 'true'; },
    toggle() { this.muted = !this.muted; localStorage.setItem('audioMuted', String(this.muted)); }
  }"
  x-bind:aria-pressed="String(muted)"
  x-bind:aria-label="muted ? 'Unmute sounds' : 'Mute sounds'"
  x-bind:title="muted ? 'Unmute sounds' : 'Mute sounds'"
  x-on:click="toggle()"
  aria-pressed="false"
  aria-label="Mute sounds"
  title="Mute sounds"
  class="fixed bottom-4 right-4 z-50 flex h-12 w-12 cursor-pointer items-center justify-center rounded border border-gray-400 bg-paper-grunge text-gray-600 shadow-hard origin-center transform-gpu transition-colors active:scale-95 hover:text-gray-900 dark:border-stone-600 dark:bg-stone-800 dark:text-stone-400 dark:hover:text-stone-100"
>
  <!-- SpeakerHigh — shown when unmuted -->
  <svg
    x-show="!muted"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 256 256"
    fill="currentColor"
    width="24"
    height="24"
    aria-hidden="true"
  >
    <path
      d="M155.51,24.81a8,8,0,0,0-8.42.88L77.25,80H32A16,16,0,0,0,16,96v64a16,16,0,0,0,16,16H77.25l69.84,54.31A8,8,0,0,0,160,224V32A8,8,0,0,0,155.51,24.81ZM32,96H72v64H32ZM144,207.64,88,164.09V91.91l56-43.55Zm54-106.08a40,40,0,0,1,0,52.88,8,8,0,0,1-12-10.58,24,24,0,0,0,0-31.72,8,8,0,0,1,12-10.58ZM248,128a79.9,79.9,0,0,1-20.37,53.34,8,8,0,0,1-11.92-10.67,64,64,0,0,0,0-85.33,8,8,0,1,1,11.92-10.67A79.83,79.83,0,0,1,248,128Z"
    ></path>
  </svg>
  <!-- SpeakerX — shown when muted -->
  <svg
    x-show="muted"
    x-cloak
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 256 256"
    fill="currentColor"
    width="24"
    height="24"
    aria-hidden="true"
  >
    <path
      d="M155.51,24.81a8,8,0,0,0-8.42.88L77.25,80H32A16,16,0,0,0,16,96v64a16,16,0,0,0,16,16H77.25l69.84,54.31A8,8,0,0,0,160,224V32A8,8,0,0,0,155.51,24.81ZM32,96H72v64H32ZM144,207.64,88,164.09V91.91l56-43.55Zm101.66-61.3a8,8,0,0,1-11.32,11.32L216,139.31l-18.34,18.35a8,8,0,0,1-11.32-11.32L204.69,128l-18.35-18.34a8,8,0,0,1,11.32-11.32L216,116.69l18.34-18.35a8,8,0,0,1,11.32,11.32L227.31,128Z"
    ></path>
  </svg>
</button>
