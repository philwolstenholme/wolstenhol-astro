---
---
<button
  id="mute-toggle"
  aria-pressed="false"
  aria-label="Mute sounds"
  title="Mute sounds"
  class="fixed bottom-4 right-4 z-50 flex h-12 w-12 cursor-pointer items-center justify-center rounded-2xl bg-neutral-800 text-neutral-400 shadow-lg transition-colors hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
>
  <!-- SpeakerHigh — shown when unmuted -->
  <svg id="mute-toggle__icon--on" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" width="24" height="24" aria-hidden="true">
    <path d="M155.51,24.81a8,8,0,0,0-8.42.88L77.25,80H32A16,16,0,0,0,16,96v64a16,16,0,0,0,16,16H77.25l69.84,54.31A8,8,0,0,0,160,224V32A8,8,0,0,0,155.51,24.81ZM32,96H72v64H32ZM144,207.64,88,164.09V91.91l56-43.55Zm54-106.08a40,40,0,0,1,0,52.88,8,8,0,0,1-12-10.58,24,24,0,0,0,0-31.72,8,8,0,0,1,12-10.58ZM248,128a79.9,79.9,0,0,1-20.37,53.34,8,8,0,0,1-11.92-10.67,64,64,0,0,0,0-85.33,8,8,0,1,1,11.92-10.67A79.83,79.83,0,0,1,248,128Z"/>
  </svg>
  <!-- SpeakerX — shown when muted -->
  <svg id="mute-toggle__icon--off" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" width="24" height="24" aria-hidden="true" class="hidden">
    <path d="M155.51,24.81a8,8,0,0,0-8.42.88L77.25,80H32A16,16,0,0,0,16,96v64a16,16,0,0,0,16,16H77.25l69.84,54.31A8,8,0,0,0,160,224V32A8,8,0,0,0,155.51,24.81ZM32,96H72v64H32ZM144,207.64,88,164.09V91.91l56-43.55Zm101.66-61.3a8,8,0,0,1-11.32,11.32L216,139.31l-18.34,18.35a8,8,0,0,1-11.32-11.32L204.69,128l-18.35-18.34a8,8,0,0,1,11.32-11.32L216,116.69l18.34-18.35a8,8,0,0,1,11.32,11.32L227.31,128Z"/>
  </svg>
</button>

<script>
  const btn = document.getElementById("mute-toggle")!;
  const iconOn = document.getElementById("mute-toggle__icon--on")!;
  const iconOff = document.getElementById("mute-toggle__icon--off")!;

  function applyMuteState(muted: boolean) {
    iconOn.classList.toggle("hidden", muted);
    iconOff.classList.toggle("hidden", !muted);
    btn.setAttribute("aria-pressed", String(muted));
    btn.setAttribute("aria-label", muted ? "Unmute sounds" : "Mute sounds");
    btn.setAttribute("title", muted ? "Unmute sounds" : "Mute sounds");
  }

  applyMuteState(localStorage.getItem("audioMuted") === "true");

  btn.addEventListener("click", () => {
    const nowMuted = !(localStorage.getItem("audioMuted") === "true");
    localStorage.setItem("audioMuted", String(nowMuted));
    applyMuteState(nowMuted);
  });
</script>
