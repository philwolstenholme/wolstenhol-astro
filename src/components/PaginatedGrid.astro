---
import { paginate } from "../helpers/paginate";
import Pagination from "./Pagination.astro";

const {
  anchor,
  htmxPartialPath,
  itemComponent: Item,
  items,
  itemsPerPage,
  nextUrl,
  onlyFullPages = true,
  pageUrl,
  prevUrl,
  searchParam = "page",
  staticMode = false,
} = Astro.props as {
  anchor?: string;
  htmxPartialPath?: string;
  itemComponent: any; // Component expected to output its own <li>
  items: readonly unknown[];
  itemsPerPage: number;
  nextUrl?: null | string;
  onlyFullPages?: boolean;
  pageUrl?: URL;
  prevUrl?: null | string;
  searchParam?: string;
  staticMode?: boolean;
};

const { data, hasNext, hasPrev, nextIndex, prevIndex } = staticMode
  ? {
      data: items as unknown[],
      hasNext: nextUrl != null,
      hasPrev: prevUrl != null,
      nextIndex: null as null,
      prevIndex: null as null,
    }
  : paginate({
      items,
      itemsPerPage,
      onlyFullPages,
      searchParam,
      url: new URL(Astro.request.url),
    });

const htmxAttrs = staticMode
  ? {}
  : {
      "@htmx:after-swap": `$event.target.id === 'paginated-grid-${searchParam}' && $focus.within($event.target).first()`,
      "x-data": "",
    };
---

{
  data && data.length > 0 ? (
    <div {...htmxAttrs}>
      <div id={`paginated-grid-${searchParam}`}>
        <ul class="grid gap-4 grid-cols-[repeat(auto-fit,minmax(330px,1fr))]">
          {data.map((item: any) => (
            <Item key={item.id} item={item} />
          ))}
        </ul>
        <Pagination
          anchor={anchor}
          hasPrev={hasPrev}
          hasNext={hasNext}
          prevIndex={prevIndex}
          nextIndex={nextIndex}
          searchParam={searchParam}
          htmxPartialPath={htmxPartialPath}
          pageUrl={pageUrl}
          itemsPerPage={itemsPerPage}
          prevUrl={prevUrl}
          nextUrl={nextUrl}
        />
      </div>
    </div>
  ) : (
    <slot name="empty" />
  )
}
