---
export interface ContentProps {
  as?: string;
  class?: string;
}
const { as = "div", class: extraClass = "" } = Astro.props;
const As = as;
---

<style is:global>
  @reference "tailwindcss";

  :root {
    --space: 1rem;
    --space-md: 1.25rem;
    --content-max-width: 100%;

    @media (min-width: 640px) {
      --content-max-width: 540px;
    }

    @media (min-width: 768px) {
      --content-max-width: 720px;
    }

    @media (min-width: 1024px) {
      --content-max-width: 960px;
    }

    @media (min-width: 1280px) {
      --content-max-width: calc(72rem - 16px);
    }
  }

  .constrain-content {
    display: grid;
    grid-template-columns:
      [full-start] 1fr
      [content-start]
      min(var(--content-max-width), 100% - var(--space-md) * 2)
      [content-end]
      1fr [full-end];
  }

  @layer base {
    :where(.constrain-content) > * {
      grid-column: content;
    }
  }
</style>

<As class={["constrain-content", extraClass].filter(Boolean).join(" ")}>
  <slot />
</As>
