---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { sortBy } from "es-toolkit";

import Section from "./Section.astro";

interface Props {
  collection?: CollectionEntry<"dev-to-posts">[];
}
import Lede from "./Lede.astro";
import StyledTextLink from "./StyledTextLink.astro";
import PaginatedGrid from "./PaginatedGrid.astro";
import DevToPostCard from "./items/DevToPostCard.astro";

const { collection: collectionProp } = Astro.props;

const searchParam = "posts";
const anchor = "posts";
const itemsPerPage = 3;
const collection = collectionProp || (await getCollection("dev-to-posts"));

const items = sortBy(collection, [(entry) => entry.data.published_at ?? ""])
  .reverse()
  .map((entry) => entry.data);
---

<Section id="words" heading="Words">
  <Lede>
    <p class="max-w-3xl font-serif leading-relaxed tracking-widest mt-3">
      Blog posts I've posted on <StyledTextLink href="https://dev.to/philw_"
        >DEV Community</StyledTextLink
      > or <StyledTextLink href="https://philwolstenholme.medium.com"
        >Medium</StyledTextLink
      > (one day I'll build my own blog, I promise…)
    </p>
  </Lede>
  <div class="mt-8">
    <PaginatedGrid
      items={items}
      itemsPerPage={itemsPerPage}
      searchParam={searchParam}
      anchor={anchor}
      itemComponent={DevToPostCard}
      htmxPartialPath="/partials/posts"
    >
      <div slot="empty" class="text-center text-gray-500 py-8">
        No posts found.
      </div>
    </PaginatedGrid>
  </div>
</Section>
