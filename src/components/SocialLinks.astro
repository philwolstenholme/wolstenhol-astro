---
import CurvyArrow from "./icons/CurvyArrow.astro";

const introButton =
  "inline-flex items-center gap-2 flex-shrink-0 border border-current rounded px-4 py-1 font-bold select-none text-yellow-400 hocus:text-yellow-500";
const introLink =
  "text-yellow-400 underline hocus:text-yellow-500 hue-rotate font-bold";
---

<ul
  role="list"
  class="hue-rotate-links -m-2 flex list-none flex-wrap items-center p-0"
>
  <li class="m-2">
    <a
      rel="me"
      href="https://bsky.app/profile/wolstenhol.me"
      class={introButton}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.206-.659-.298-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8Z"
        ></path>
      </svg>
      <span>Bluesky</span>
    </a>
  </li>
  <li class="m-2">
    <a rel="me" href="https://github.com/philwolstenholme" class={introButton}>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
        ></path>
      </svg>
      <span>GitHub</span>
    </a>
  </li>
  <li class="m-2 w-full md:w-auto">
    <a
      rel="me"
      href="https://www.linkedin.com/in/phil-wolstenholme"
      class={introLink}
    >
      LinkedIn
    </a>
    <span class="hue-rotate text-xs text-yellow-400">
      <CurvyArrow class="inline-block h-2 pr-1 pl-2" height="10" />
      so <sup aria-hidden="true">✨</sup>
      <em class="not-italic">professional</em>
      <sub aria-hidden="true">✨</sub>…
    </span>
  </li>
  <li class="m-2">
    <a rel="me" href="https://twitter.com/philw_" class={introLink}>Twitter</a>
  </li>
  <li class="m-2">
    <a href="/contact" class={introLink}>Email</a>
  </li>
  <li class="m-2">
    <a
      rel="me"
      href="https://www.drupal.org/u/phil-wolstenholme"
      class={introLink}>Drupal.org</a
    >
  </li>
</ul>
