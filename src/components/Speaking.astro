---
import type { CollectionEntry } from "astro:content";

import { getCollection } from "astro:content";

import { sortSpeaking } from "../helpers/getSpeakingSorted";
import HorizontalScroller from "./HorizontalScroller.astro";
import SpeakingCard from "./items/SpeakingCard.astro";
import Lede from "./Lede.astro";
import Section from "./Section.astro";

interface Props {
  collection?: CollectionEntry<"speaking">[];
}

const { collection: collectionProp } = Astro.props;
const collection = collectionProp || (await getCollection("speaking"));
const items = sortSpeaking(collection);
---

<Section id="speaking" hasScroller heading="Speaking">
  <Lede>
    Talks I've given at conferences or other events. I'll link to slides or
    videos where they are available.
  </Lede>
  <HorizontalScroller
    class="mt-12"
    label="Public speaking that I've done"
    theme="speaking"
  >
    {
      items.map((item) => (
        <li class="relative flex mb-3 shrink-0 grow-0 snap-center">
          <SpeakingCard
            item={item}
            class={
              item.type === "thumbnail"
                ? "snap-start shrink-0 grow-0 w-68"
                : "snap-start shrink-0 grow-0 w-91.25"
            }
          />
        </li>
      ))
    }
  </HorizontalScroller>
</Section>
