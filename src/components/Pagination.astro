---
import PaginationButton from "./PaginationButton.astro";

const {
  hasPrev,
  hasNext,
  prevIndex,
  nextIndex,
  searchParam,
  htmxPartialPath,
  pageUrl,
  itemsPerPage,
  prevUrl,
  nextUrl,
} = Astro.props as {
  hasPrev: boolean;
  hasNext: boolean;
  prevIndex: number | null;
  nextIndex: number | null;
  searchParam: string;
  htmxPartialPath?: string;
  pageUrl?: URL;
  itemsPerPage?: number;
  prevUrl?: string | null;
  nextUrl?: string | null;
};

// When rendered inside a partial response, Astro.request.url is the partial
// endpoint URL. pageUrl carries the real page URL (from HX-Current-Url) so
// that href values point to the main page rather than the partial endpoint.
const currentUrl = pageUrl ?? new URL(Astro.request.url);
---

<div class="flex justify-center mt-4 gap-4">
  {
    hasPrev && (
      <PaginationButton
        direction="prev"
        index={prevIndex}
        url={prevUrl}
        currentUrl={currentUrl}
        searchParam={searchParam}
        htmxPartialPath={htmxPartialPath}
        itemsPerPage={itemsPerPage}
      />
    )
  }
  {
    hasNext && (
      <PaginationButton
        direction="next"
        index={nextIndex}
        url={nextUrl}
        currentUrl={currentUrl}
        searchParam={searchParam}
        htmxPartialPath={htmxPartialPath}
        itemsPerPage={itemsPerPage}
      />
    )
  }
</div>
