---
// Sits next to the mute toggle. The theme itself is applied to <html> by the
// inline script in Layout's <head> before first paint; this button just flips
// it. System preference is the primary source of truth: an explicit choice is
// stored in localStorage, and toggling back to whatever the system currently
// prefers clears the override so the site follows the OS again.
---

<button
  id="theme-toggle"
  x-data="{
    toggle() {
      const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
      const system = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      if (next === system) { localStorage.removeItem('theme'); } else { localStorage.setItem('theme', next); }
      document.documentElement.dataset.theme = next;
    }
  }"
  x-on:click="toggle()"
  aria-label="Switch between dark and light theme"
  title="Switch between dark and light theme"
  class="fixed bottom-4 right-18 z-50 flex h-12 w-12 cursor-pointer items-center justify-center rounded border border-gray-400 bg-paper-grunge text-gray-600 shadow-hard origin-center transform-gpu transition-colors active:scale-95 hover:text-gray-900 dark:border-stone-600 dark:bg-stone-800 dark:text-stone-400 dark:hover:text-stone-100"
>
  <!-- Moon — shown in light mode (switches to dark). Visibility is pure CSS
       so the right icon shows even before Alpine hydrates. -->
  <svg
    class="dark:hidden"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 256 256"
    fill="currentColor"
    width="24"
    height="24"
    aria-hidden="true"
  >
    <path
      d="M233.54,142.23a8,8,0,0,0-8-2,88.08,88.08,0,0,1-109.8-109.8,8,8,0,0,0-10-10,104.84,104.84,0,0,0-52.91,37A104,104,0,0,0,136,224a103.09,103.09,0,0,0,62.52-20.88,104.84,104.84,0,0,0,37-52.91A8,8,0,0,0,233.54,142.23ZM188.9,190.34A88,88,0,0,1,65.66,67.11a89,89,0,0,1,31.4-26A106,106,0,0,0,96,56,104.11,104.11,0,0,0,200,160a106,106,0,0,0,14.92-1.06A89,89,0,0,1,188.9,190.34Z"
    ></path>
  </svg>
  <!-- Sun — shown in dark mode (switches to light) -->
  <svg
    class="hidden dark:block"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 256 256"
    fill="currentColor"
    width="24"
    height="24"
    aria-hidden="true"
  >
    <path
      d="M120,40V16a8,8,0,0,1,16,0V40a8,8,0,0,1-16,0Zm72,88a64,64,0,1,1-64-64A64.07,64.07,0,0,1,192,128Zm-16,0a48,48,0,1,0-48,48A48.05,48.05,0,0,0,176,128ZM58.34,69.66A8,8,0,0,0,69.66,58.34l-16-16A8,8,0,0,0,42.34,53.66Zm0,116.68-16,16a8,8,0,0,0,11.32,11.32l16-16a8,8,0,0,0-11.32-11.32ZM192,72a8,8,0,0,0,5.66-2.34l16-16a8,8,0,0,0-11.32-11.32l-16,16A8,8,0,0,0,192,72Zm5.66,114.34a8,8,0,0,0-11.32,11.32l16,16a8,8,0,0,0,11.32-11.32ZM48,128a8,8,0,0,0-8-8H16a8,8,0,0,0,0,16H40A8,8,0,0,0,48,128Zm80,80a8,8,0,0,0-8,8v24a8,8,0,0,0,16,0V216A8,8,0,0,0,128,208Zm112-88H216a8,8,0,0,0,0,16h24a8,8,0,0,0,0-16Z"
    ></path>
  </svg>
</button>
