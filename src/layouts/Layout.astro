---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import MuteToggle from "../components/MuteToggle.astro";
import StyledTextLink from "../components/StyledTextLink.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import "../styles/global.css";
type Props = {
  hasTitleSuffix?: boolean;
  title?: string;
};
const { hasTitleSuffix = true, title = "Phil Wolstenholme" } = Astro.props;
const titleSuffix = " | Phil Wolstenholme";
const fullTitle = hasTitleSuffix ? `${title}${titleSuffix}` : title;

if (Astro.response) {
  Astro.response.headers.set(
    "Cache-Control",
    "public, max-age=0, must-revalidate",
  );
}

// Decorative coffee-stain images scattered behind the page content. Only the
// first is in the initial viewport, so it loads eagerly.
const coffeeStains = [
  {
    class: "",
    eager: true,
    height: 451,
    style: "left: -230px; top: 600px",
    width: 500,
  },
  {
    class: "object-cover object-left",
    eager: false,
    height: 405,
    style: "right: 0; top: 1900px; height: 405px; width: 9%",
    width: 112,
  },
  {
    class: "-rotate-45",
    eager: false,
    height: 451,
    style: "left: -230px; top: 2900px",
    width: 500,
  },
];
---

<!doctype html>
<html lang="en" data-props-for="network">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      // Decide the theme before first paint to avoid a flash of the wrong
      // theme. System preference is primary; an explicit user choice in
      // localStorage overrides it. Runs again on pageshow/prerenderingchange
      // so speculation-rules prerendered pages pick up a toggle made after
      // they were rendered, and on storage so other tabs stay in sync.
      (() => {
        const mq = window.matchMedia("(prefers-color-scheme: dark)");
        const apply = () => {
          const stored = localStorage.getItem("theme");
          document.documentElement.dataset.theme =
            stored === "dark" || stored === "light"
              ? stored
              : mq.matches
                ? "dark"
                : "light";
        };
        apply();
        mq.addEventListener("change", apply);
        window.addEventListener("pageshow", apply);
        document.addEventListener("prerenderingchange", apply);
        window.addEventListener("storage", (event) => {
          if (event.key === "theme") {
            apply();
          }
        });
      })();
    </script>
    <script is:inline>
      /* oxlint-disable no-unused-expressions -- vendored minified snippet */
      (function () {
        "use strict";
        var o = {
          constPrefix: "--const-",
          root: typeof document < "u" ? document.documentElement : void 0,
        };
        function s() {
          let e = document.createElement("div"),
            i = o.root,
            t = (n, r) => i.style.setProperty(o.constPrefix + n, String(r));
          ((e.style.cssText =
            "position:absolute;top:-9999px;width:100px;height:100px;overflow:scroll;visibility:hidden"),
            (document.body ?? i).appendChild(e),
            t("scrollbar-w", e.offsetWidth - e.clientWidth),
            (e.style.scrollbarWidth = "thin"),
            t("scrollbar-thin-w", e.offsetWidth - e.clientWidth),
            e.remove(),
            t("dpr", window.devicePixelRatio || 1),
            t("cores", navigator.hardwareConcurrency || 0),
            t("mem", navigator.deviceMemory || 0));
        }
        typeof document < "u" && s();
      })();
    </script>
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="preconnect" href="https://res.cloudinary.com" />
    <!-- Font preloads are injected by the subfont build integration (integrations/subfont.ts). -->
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/favicon/apple-touch-icon.png"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/favicon/favicon-32x32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/favicon/favicon-16x16.png"
    />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    <link
      rel="mask-icon"
      href="/favicon/safari-pinned-tab.svg"
      color="#666666"
    />
    <meta name="msapplication-TileColor" content="#fbbf24" />
    <meta name="msapplication-config" content="/favicon/browserconfig.xml" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="noindex, nofollow" />
    <title>{fullTitle}</title>
    <meta name="view-transition" content="same-origin" />
    <meta name="description" content="Phil Wolstenholme's personal site" />
    <link rel="canonical" href="https://wolstenhol.me/" />
    <meta property="og:site_name" content="Phil Wolstenholme" />
    <meta property="og:title" content={fullTitle} />
    <meta property="twitter:title" content={fullTitle} />
    <meta
      property="og:description"
      content="Phil Wolstenholme's personal site"
    />
    <meta
      property="twitter:description"
      content="Phil Wolstenholme's personal site"
    />
    <meta property="og:url" content="https://wolstenhol.me/" />
    <meta property="og:locale" content="en_gb" />
    <meta property="og:type" content="website" />
    <meta name="twitter:site" content="@philw_" />
    <meta name="twitter:creator" content="@philw_" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="image"
      property="og:image"
      content="https://wolstenhol.me/og?title=Phil%20Wolstenholme's%20personal%20website%2C%20blog%20and%20portfolio&url=https%3A%2F%2Fwolstenhol.me%2F&v=1.5.0"
    />
    <meta
      property="og:image:alt"
      content="Phil Wolstenholme's personal website, blog and portfolio, a webpage by Phil Wolstenholme, @philw_"
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="My posts on dev.to"
      href="https://dev.to/feed/philw_"
    />
    <meta name="theme-color" content="#161616" />
    <noscript>
      <style>
        main section + section,
        main .card--portfolio + .card--portfolio {
          contain-intrinsic-size: unset;
          content-visibility: unset;
        }
      </style>
    </noscript>
  </head>
  <body class="bg-subtle-grunge slow-connection:bg-none dark:text-stone-200">
    <div
      class="pointer-events-none absolute inset-0 overflow-hidden"
      aria-hidden="true"
    >
      {
        coffeeStains.map((stain) => (
          <img
            class={`absolute opacity-40 mix-blend-multiply slow-connection:hidden dark:opacity-15 dark:mix-blend-screen dark:invert ${stain.class}`}
            loading={stain.eager ? "eager" : "lazy"}
            fetchpriority={stain.eager ? "high" : undefined}
            decoding={stain.eager ? undefined : "async"}
            alt=""
            width={stain.width}
            height={stain.height}
            srcset="
              /proxy/cloudinary/image/upload/c_scale,q_10,w_500,fl_progressive/v1614122419/one-offs/cup-coffee-stain-2.jpg  1x,
              /proxy/cloudinary/image/upload/c_scale,q_10,w_1000,fl_progressive/v1614122419/one-offs/cup-coffee-stain-2.jpg 2x
            "
            style={stain.style}
          />
        ))
      }
    </div>
    <Header />
    {
      Astro.cookies.has("hideWipBanner") === false && (
        <div
          id="wip-banner"
          class="border-b border-black z-50 flex py-2 gap-4 top-0 pr-4 bg-yellow-300 text-black text-sm md:text-base"
        >
          <marquee>
            This is a work in progress, my real website is{" "}
            <StyledTextLink href="https://wolstenhol.me/">
              https://wolstenhol.me
            </StyledTextLink>
          </marquee>
          <button
            class="shrink-0 underline"
            onclick="document.getElementById('wip-banner').style.display='none'; document.cookie = 'hideWipBanner=true; max-age=' + 60*60*24*5 + '; path=/';"
          >
            Close me
          </button>
        </div>
      )
    }
    <slot />
    <Footer />
    <ThemeToggle />
    <MuteToggle />
    <script src="../assets/audio-interactions.ts"></script>
    <script>
      import "../assets/htmx.ts";
    </script>
    <script>
      import "../assets/alpine.ts";
    </script>
    <script>
      import "../assets/prop-for-that.ts";
    </script>
    <script>
      import "../assets/content-visibility.ts";
    </script>
    <script is:inline type="speculationrules">
      {
        "prerender": [
          {
            "source": "document",
            "where": {
              "and": [
                { "href_matches": "/*" },
                { "not": { "selector_matches": ".no-prerender" } },
                { "not": { "selector_matches": "[rel~=nofollow]" } }
              ]
            },
            "eagerness": "eager"
          }
        ]
      }
    </script>
  </body>
</html>

<style is:global>
  body {
    position: relative;
    min-height: 100vh;
    display: grid;
    /* Without an explicit column, the auto implicit column expands to the
       max-content size of any horizontal scroller. minmax(0, 1fr) caps it
       at the viewport width by allowing the track to shrink to 0. */
    grid-template-columns: minmax(0, 1fr);
  }
</style>
