{
  "name": "wolstenhol-astro",
  "version": "0.0.1",
  "license": "AGPL-3.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "prepare": "simple-git-hooks",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix src/",
    "format": "oxfmt . && prettier --write \"src/**/*.astro\"",
    "format:check": "oxfmt --check . && prettier --check \"src/**/*.astro\""
  },
  "dependencies": {
    "@astrojs/netlify": "^7.0.13",
    "@astrojs/preact": "^5.1.5",
    "@octokit/types": "^16.0.0",
    "@sindresorhus/slugify": "^3.0.0",
    "@tailwindcss/vite": "^4.3.1",
    "@web-kits/audio": "^0.1.0",
    "astro": "^6.4.7",
    "clsx": "^2.1.1",
    "es-toolkit": "^1.47.1",
    "markdown-to-txt": "^2.0.1",
    "octokit": "^5.0.5",
    "preact": "^10.29.2",
    "tailwindcss": "^4.3.1",
    "ua-parser-js": "^2.0.10"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "nano-staged": "^1.0.2",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "prettier": "3.6.2",
    "prettier-plugin-astro": "0.14.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3"
  },
  "simple-git-hooks": {
    "pre-commit": "node_modules/.bin/nano-staged"
  },
  "nano-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "*.{css,json}": "oxfmt",
    "*.astro": "prettier --write"
  }
}
