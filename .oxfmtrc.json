{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["netlify.toml"],
  "tabWidth": 2,
  "useTabs": false,
  "htmlWhitespaceSensitivity": "css",
  "trailingComma": "all",
  "sortTailwindcss": true,
  "sortPackageJson": true,
  "sortImports": true,
  "ignoreFiles": ["netlify.toml"]
}
